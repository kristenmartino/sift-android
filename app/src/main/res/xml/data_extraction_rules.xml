<?xml version="1.0" encoding="utf-8"?>
<!-- Backup + transfer rules for Android 12+ -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="sift.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="sift.db" />
    </device-transfer>
</data-extraction-rules>
