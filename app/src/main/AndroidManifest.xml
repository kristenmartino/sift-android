<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- INTERNET — talk to sift / sift-api. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- POST_NOTIFICATIONS — Android 13+ runtime permission for FCM. We request
         this at intent time (after a user taps "Notify me about X"), never on
         first launch, per Material guidelines. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SiftApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sift"
        tools:targetApi="35">

        <!-- Main launcher. Single-Activity architecture; navigation handled via
             Compose Navigation inside this activity. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Sift">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Universal links — opens article URLs in-app when installed.
                 Verification via assetlinks.json hosted at
                 https://siftnews.kristenmartino.ai/.well-known/assetlinks.json
                 (deployed in a sibling sift-repo PR). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="siftnews.kristenmartino.ai" />
                <data android:pathPrefix="/article/" />
                <data android:pathPrefix="/news" />
            </intent-filter>
        </activity>

        <!-- Share-target — receives ACTION_SEND from Safari, Chrome, Messages,
             etc. Sends URL to sift-api /v1/share/sift-this endpoint, opens
             MainActivity to a temporary detail screen showing the result. -->
        <activity
            android:name=".ui.share.ShareTargetActivity"
            android:exported="true"
            android:label="@string/share_to_sift"
            android:theme="@style/Theme.Sift.Translucent">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- FCM service. Implemented in push/SiftFirebaseMessagingService.kt
             in a follow-up PR. -->
        <!--
        <service
            android:name=".push.SiftFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->

    </application>
</manifest>
